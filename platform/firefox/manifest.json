{
  "manifest_version": 3,
  "name": "Steam Power Tools",
  "version": "1.3.0",
  "description": "Mass ignore games via Ctrl+Click and automate Discovery Queue.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/*"
      ],
      "js": [
        "src/utils.js",
        "src/module_ignore.js",
        "src/module_queue.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon16.png"
      ],
      "matches": [
        "https://store.steampowered.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "steam-power-tools@example.com",
      "strict_min_version": "109.0"
    }
  }
}