{
  "manifest_version": 3,
  "name": "Steam Ignore Like A Pro",
  "version": "1.0.0",
  "description": "Helper tool for ignoring games in the Steam Store.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/*"
      ],
      "js": [
        "src/utils.js",
        
        "src/manual-ignore/utils.js",
        "src/manual-ignore/ui.js",
        "src/manual-ignore/main.js",
        
        "src/discovery-queue/ui.js",
        "src/discovery-queue/logic.js",
        "src/discovery-queue/main.js",

        "src/explore-queue/utils.js",
        "src/explore-queue/ui.js",
        "src/explore-queue/automator.js",
        "src/explore-queue/main.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon16.png"
      ],
      "matches": [
        "https://store.steampowered.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "steam-power-tools@example.com",
      "strict_min_version": "109.0"
    }
  }
}